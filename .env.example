SERVER_PORT=8080

DATABASE_DSN=postgres://user:password@localhost:5432/gandm?sslmode=disable

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=documents
S3_USE_SSL=false

# Радиусы матчинга (км) по стране точки: Китай шире (грузы из промзон/уездов
# в 50-100 км от центра), Казахстан и прочие страны — уже.
MATCH_RADIUS_CN_KM=100
MATCH_RADIUS_KZ_KM=40

# Лимиты открытия контактов на клиента (за всё время): без подписки / с подпиской
CONTACT_LIMIT_FREE=1
CONTACT_LIMIT_SUBSCRIBED=5

# Python-сервис консолидации (matching/). Лимиты вместимости — в БД
# (platform_settings), редактируются в админке.
MATCHING_SERVICE_URL=http://localhost:8000

# Платёжный провайдер: пока только sandbox (фейковые платежи без денег).
# Реальный провайдер подключается реализацией интерфейса payment.Provider.
PAYMENT_PROVIDER=sandbox

# Общий секрет с matching-сервисом (заголовок X-Internal-Token). Пусто —
# без аутентификации (локальная разработка, сервис слушает только localhost).
# Для прода: задать одинаковое значение и здесь, и в env matching-сервиса
# (MATCHING_SHARED_SECRET).
# MATCHING_SHARED_SECRET=

# Лимит запросов к login/register/refresh с одного IP в минуту (защита от
# перебора паролей). Для локальной разработки и smoke-тестов (все запросы с
# одного IP) поднимите до 1000.
LOGIN_RATE_LIMIT_PER_MIN=10
