# Base path for API calls. Left as "/api" by default so requests go through
# the Vite dev proxy configured in vite.config.ts (see there for the target
# port). Only override this if you're pointing the frontend at a backend
# that isn't reachable via the dev proxy (e.g. a deployed API).
VITE_API_BASE_URL=/api

# Ключ Amap (Gaode) для китайской карты. Без него вкладка «Китай» в выборе
# точки покажет понятную заглушку вместо карты. Ключ живёт во frontend-env
# (карта работает в браузере, backend Amap не вызывает), поэтому префикс
# VITE_ обязателен — иначе Vite не отдаст переменную в код.
VITE_AMAP_KEY=
